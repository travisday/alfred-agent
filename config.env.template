# /alfred/config.env — Alfred preferences
# Railway env vars always override these values.
# Uncomment and edit any line to customize.

# --- Timezone (IANA) ---
# TIMEZONE=America/Los_Angeles

# --- Default model (used by all channels: proactive, Discord, subagent) ---
# ALFRED_MODEL=groq/llama-3.3-70b-versatile

# --- Proactive check-ins ---
# PROACTIVE_SCHEDULE=8:00,12:00,18:00
# PROACTIVE_MODEL=groq/llama-3.3-70b-versatile
# PROACTIVE_THINKING=off
# PROACTIVE_POLL_SECS=300

# --- Discord ---
# DISCORD_DM_POLICY=open
# DISCORD_OWNER_USER_ID=
# DISCORD_PROACTIVE_USER_ID=
# DISCORD_ALLOWED_USER_IDS=
# DISCORD_PROMPT_TIMEOUT_MS=300000
# DISCORD_TASK_TIMEOUT_MS=1800000

# --- Sub-agent ---
# DELEGATE_TASK_TIMEOUT_MS=300000

# --- Default model ---
# Single knob for model across all channels. Proactive scripts use this as
# fallback (PROACTIVE_MODEL overrides if set). Discord and subagent sessions
# use Pi's built-in resolution but ALFRED_MODEL is exported to the environment.
# ALFRED_MODEL=groq/llama-3.3-70b-versatile

# --- CalDAV (Apple Calendar) ---
# CALDAV_SERVER_URL=https://caldav.icloud.com
# CALDAV_USERNAME=

# --- Proactive root ---
# PROACTIVE_ROOT=/alfred/proactive
