# .env.example — Alfred Agent configuration reference
# Copy to .env and fill in values for your deployment platform.
#
# Hierarchy: Platform env vars (Railway, Docker) > /alfred/config.env > defaults
# Secrets (API keys, tokens) must be set as env vars — never commit them.
# Preferences (timezone, model, schedule) can also go in /alfred/config.env
# on the persistent volume for runtime tuning without redeployment.

# ──────────────────────────────────────────────
# REQUIRED
# ──────────────────────────────────────────────

# Tailscale — required for SSH access
TS_AUTHKEY=

# LLM provider — at least one required
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# ──────────────────────────────────────────────
# DISCORD (optional — enables DM interface)
# ──────────────────────────────────────────────

# DISCORD_BOT_TOKEN=
# DISCORD_OWNER_USER_ID=           # Your Discord user ID (snowflake)
# DISCORD_DM_POLICY=open           # open | owner_only | allowlist
# DISCORD_ALLOWED_USER_IDS=        # Comma-separated IDs (for allowlist policy)
# DISCORD_PROMPT_TIMEOUT_MS=300000 # Foreground message timeout (5 min)
# ALFRED_PI_SESSION_DIR=               # Optional override; default Pi session: ~/.pi/agent/sessions/--alfred--/
# ALFRED_MEMORY_LOADER_PATH=/opt/memory-loader.sh   # Prepends blocks/*.yaml each DM
# ALFRED_MEMORY_ROOT=/alfred             # Memory repo root for memory-loader (blocks/)
# DISCORD_PROACTIVE_USER_ID=            # Optional: recipient for send_discord_message (else DISCORD_OWNER_USER_ID)
# ALFRED_EVENT_FILE=/root/.pi/agent/events.jsonl      # discord-notify event log (optional)

# ──────────────────────────────────────────────
# CALENDAR — CalDAV (optional — Apple Calendar via iCloud)
# ──────────────────────────────────────────────

# CALDAV_USERNAME=                             # Apple ID email
# CALDAV_APP_PASSWORD=                         # App-specific password (generate at appleid.apple.com)
# CALDAV_SERVER_URL=https://caldav.icloud.com  # CalDAV endpoint
# CALDAV_TIMEZONE=                             # Override timezone for calendar (defaults to TIMEZONE)

# ──────────────────────────────────────────────
# WEB SEARCH (optional)
# ──────────────────────────────────────────────

# TAVILY_API_KEY=

# ──────────────────────────────────────────────
# GENERAL PREFERENCES
# ──────────────────────────────────────────────

# TIMEZONE=America/Los_Angeles                 # IANA timezone for all subsystems
# ALFRED_MODEL=                                # Default model (provider/model-id, e.g. anthropic/claude-sonnet-4-5-20250929)

# ──────────────────────────────────────────────
# ADVANCED / INTERNAL
# ──────────────────────────────────────────────

# SSH_PASSWORD=changeme                        # Root password for SSH access
# GITHUB_TOKEN=                                # GitHub PAT for memory repo push
# DELEGATE_TASK_TIMEOUT_MS=300000              # Sub-agent delegation timeout
# RAILWAY_RUN_UID=0                            # Container runs as root
